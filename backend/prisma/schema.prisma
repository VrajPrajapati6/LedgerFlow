generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum AccountStatus {
  ACTIVE
  BLOCKED
  CLOSED
}

enum EntryType {
  DEBIT
  CREDIT
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
  REVERSED
}

model Account {
  id          String        @id @default(uuid())
  userId      String
  accountType String
  currency    String
  status      AccountStatus @default(ACTIVE)
  createdAt   DateTime      @default(now())

  ledgerEntries LedgerEntry[]
  snapshots     Snapshot[]
  fraudAlerts   FraudAlert[]
}

model Transaction {
  id          String             @id @default(uuid())
  reference   String?
  status      TransactionStatus  @default(PENDING)
  createdAt   DateTime           @default(now())

  ledgerEntries LedgerEntry[]
  fraudAlerts   FraudAlert[]
}

model LedgerEntry {
  id            String      @id @default(uuid())
  accountId     String
  transactionId String
  entryType     EntryType
  amount        Decimal
  description   String?
  createdAt     DateTime    @default(now())

  account       Account     @relation(fields: [accountId], references: [id])
  transaction   Transaction @relation(fields: [transactionId], references: [id])
}

model Snapshot {
  id          String    @id @default(uuid())
  accountId   String
  balance     Decimal
  lastEventId String
  createdAt   DateTime  @default(now())

  account     Account   @relation(fields: [accountId], references: [id])
}

model FraudAlert {
  id             String   @id @default(uuid())
  transactionId  String
  accountId      String
  riskScore      Int
  severity       String   // "LOW" | "MEDIUM" | "HIGH"
  triggeredRules String[]
  createdAt      DateTime @default(now())

  transaction    Transaction @relation(fields: [transactionId], references: [id])
  account        Account     @relation(fields: [accountId], references: [id])
}

model ExternalSettlement {
  id                  String   @id @default(uuid())
  transactionId       String
  amount              Decimal
  status              String   // "SUCCESS" | "FAILED"
  settlementTimestamp DateTime
  createdAt           DateTime @default(now())
}

model ReconciliationRun {
  id              String                  @id @default(uuid())
  totalMatched    Int
  totalMismatched Int
  createdAt       DateTime                @default(now())
  failures        ReconciliationFailure[]
}

model ReconciliationFailure {
  id            String            @id @default(uuid())
  runId         String
  transactionId String
  mismatchType  String            // "MISSING_SETTLEMENT" | "AMOUNT_MISMATCH" | "STATUS_MISMATCH" | "DUPLICATE_SETTLEMENT"
  details       String?
  createdAt     DateTime          @default(now())
  run           ReconciliationRun @relation(fields: [runId], references: [id], onDelete: Cascade)
}